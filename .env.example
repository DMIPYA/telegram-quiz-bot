# Токен Telegram-бота (обязательно) — получите у @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# API-ключ NVIDIA NIM (обязательно) — нужен для /generate
NVIDIA_API_KEY=your_nvidia_api_key_here
# Базовый URL NVIDIA NIM (необязательно, есть значение по умолчанию)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Модель NVIDIA NIM (необязательно, есть значение по умолчанию)
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
# Telegram user_id админов через запятую — кому доступна команда /generate
ADMIN_USER_IDS=123456789,987654321